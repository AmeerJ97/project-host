# Configuration for sweep.sh
# Copy this file to sweep_config.sh and adjust values for the target system.
# All variables have default values in sweep.sh; override only what is needed.

# GPU
EXPECTED_DRIVER_VERSION="590"
EXPECTED_POWER_LIMIT="140"
EXPECTED_PERSISTENCE_MODE="Enabled"
EXPECTED_BAR1_TOTAL="16384"
EXPECTED_PCIE_GEN="4"

# GPU Direct Memory
EXPECTED_UVM_CACHE_SYSMEM="1"
EXPECTED_UVM_CACHE_PEERMEM="1"
EXPECTED_UVM_PREFETCH_THRESHOLD="75"

# CUDA
EXPECTED_CUDA="cuda"

# Ollama
EXPECTED_OLLAMA_SERVICE="active"

# Docker
EXPECTED_DOCKER_RUNTIME="nvidia"

# CPU
EXPECTED_CPU_GOVERNOR="performance"
EXPECTED_CPU_TURBO="0"

# Memory
EXPECTED_SWAPPINESS="10"
EXPECTED_HUGEPAGES="4096"
EXPECTED_THP="madvise"
EXPECTED_THP_DEFRAG="madvise"
EXPECTED_KSM="0"
EXPECTED_COMPACTION="0"
EXPECTED_NUMA_BALANCING="0"
EXPECTED_SWAP_DEVICES_MIN="2"

# I/O
EXPECTED_NVME_SCHEDULER="none"
EXPECTED_NVME_READAHEAD_KB="2048"
EXPECTED_HDD_SCHEDULER="mq-deadline"

# Network
EXPECTED_RMEM_MAX="16777216"
EXPECTED_WMEM_MAX="16777216"
EXPECTED_TCP_FASTOPEN="3"

# Boot
EXPECTED_BOOT_ASPM="pcie_aspm=off"
EXPECTED_BOOT_ZSWAP="zswap.enabled=0"
EXPECTED_BOOT_NVIDIA_DRM="nvidia-drm.modeset=1"
EXPECTED_BOOT_IOMMU="intel_iommu=on"

# Wayland
EXPECTED_SESSION_TYPE="wayland"